PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Render usually provides DATABASE_URL for Postgres. Prefer this in production.
DATABASE_URL=

# Use these for local/manual Postgres when DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jd2db
DB_USER=postgres
DB_PASSWORD=niavoit
DB_SSL=false

JWT_SECRET=change-this-before-production
ADMIN_EMAIL=admin@jd2meditech.com
ADMIN_PASSWORD=admin123

# Optional now, recommended on Render. When present, admin image uploads go to Cloudinary.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
